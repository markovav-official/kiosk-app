# Backend API URL (for REST). Example: http://localhost:8000
VITE_API_URL=http://localhost:8000
# Backend WebSocket URL for monitor. Example: ws://localhost:8000/kiosk-api/ws/monitor
VITE_WS_URL=ws://localhost:8000/kiosk-api/ws/monitor
# Auth token (must match backend AUTH_TOKEN)
VITE_AUTH_TOKEN=your-secret-token
